# Data version - auto-generated from git commit if not set
# DATA_VERSION=20260513

# Web app base URL (for local dev vs production)
# WEB_BASE_URL=http://localhost:5173

# Mobile asset path (where Flutter app expects data.json)
# MOBILE_ASSET_PATH=mobile/assets/data/

# Build output directory
# OUTPUT_DIR=docs

# Project root (for core package builds)
# PROJECT_ROOT=.
